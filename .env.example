# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=              # pooled connection — append ?pgbouncer=true
DIRECT_URL=                # direct connection (migrations only, port 5432)

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── External APIs ─────────────────────────────────────────────────────────────
# Free key from https://www.eia.gov/opendata/ — used for weekly diesel price
EIA_API_KEY=

# ── Messaging ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=      # e.g. whatsapp:+14155238886 (sandbox)

# ── Infrastructure ────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
RESEND_API_KEY=
WEBHOOK_SECRET=            # must match Cloudflare email worker secret

# ── Inngest ───────────────────────────────────────────────────────────────────
INNGEST_DEV=1              # set to 1 for local dev (disables signing key)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=       # required in production

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Next.js public (safe to expose to browser) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=       # e.g. http://localhost:3001 locally
