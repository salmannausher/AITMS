# Database (Supabase)
DATABASE_URL=
DIRECT_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Inngest (production only — not needed for local dev)
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# Webhook secret — must match the WEBHOOK_SECRET set on the Cloudflare Email Worker
WEBHOOK_SECRET=dev-secret-change-in-production

# Resend API key — used for auth emails, dispatcher alerts, and invoice sends only
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
